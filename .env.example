# JSnippets Docker Compose Environment Variables
# Copy this file to .env and customize the values

# Application Settings
APP_PORT=8080
SPRING_PROFILE=prod

# Database Settings
DB_PORT=5432
DB_PASSWORD=change_me_in_production

# JVM Options (optional, defaults are optimized)
# JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0 -XX:+UseG1GC

# For development, you can use:
# SPRING_PROFILE=development
# This will enable SQL logging and debug output

